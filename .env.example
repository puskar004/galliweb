# ── Database (Neon free-tier Postgres) ─────────────────────────────
# Get this from https://neon.tech after creating a free project
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Admin login (only YOU log in with this — clients never see /admin) ──
ADMIN_EMAIL="you@example.com"
# Generate this hash by running: npm run hash-password
# It will ask for a plain password and print the bcrypt hash to paste here.
ADMIN_PASSWORD_HASH="$2a$10$replace-this-with-generated-hash"

# ── Auth ─────────────────────────────────────────────────────────
# Any long random string. Generate one with: openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-string"

# ── Cloudinary (free tier — for shop photo uploads) ────────────────
# Get these from https://cloudinary.com dashboard after signup
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Site ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── AI shop-description generator (free tier — for the "Describe the shop,
# we'll fill the form" feature in the admin panel) ──────────────────
# Get a free key at https://console.groq.com (no credit card needed)
GROQ_API_KEY="gsk_replace-with-your-key"
